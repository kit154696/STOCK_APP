# ==========================================
# ตัวอย่างไฟล์ .env สำหรับพัฒนาในเครื่อง
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่า
# ==========================================

# PostgreSQL Connection (Railway จะตั้งให้อัตโนมัติ)
DATABASE_URL=postgresql://postgres:password@localhost:5432/stock_db

# Port (Railway จะตั้งให้อัตโนมัติ)
PORT=3000

# Session secret (ควรเปลี่ยนเป็น random string ยาวๆ ใน production)
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# CORS: domains ที่อนุญาต (คั่นด้วย comma) — ถ้าไม่ตั้ง จะอนุญาตเฉพาะ same-origin
# ตัวอย่าง: ALLOWED_ORIGINS=https://stock-app.up.railway.app,https://www.example.com
ALLOWED_ORIGINS=
